# ------------------------------------------------------------------------------
# Python caches
# ------------------------------------------------------------------------------
__pycache__/
*.pyc
*.pyo
*.pyd
*.pdb
*.pkl
*.pickle

# ------------------------------------------------------------------------------
# Build / packaging artifacts
# ------------------------------------------------------------------------------
build/
dist/
*.egg-info/
.eggs/

# ------------------------------------------------------------------------------
# Virtual environments
# ------------------------------------------------------------------------------
.env/
.venv/
venv/
env/
conda-env/

# ------------------------------------------------------------------------------
# Logs (runtime-generated)
# ------------------------------------------------------------------------------
logs/*.log

# ------------------------------------------------------------------------------
# Data directories (runtime or large files)
# ------------------------------------------------------------------------------
data/stage02_raw/
data/stage03_intermediate/
data/stage04_processed/
data/stage05_reports/

# Keep Stage 01 schema tracked
!data/stage01_schema/schema.json
!data/stage01_schema/sample_rows.csv

# Keep empty directories tracked via .gitkeep
!data/stage04_processed/.gitkeep
!data/stage05_reports/.gitkeep
!scripts/diagnostics/stage04/.gitkeep

# ------------------------------------------------------------------------------
# VSCode settings
# ------------------------------------------------------------------------------
.vscode/

# ------------------------------------------------------------------------------
# OS / editor junk
# ------------------------------------------------------------------------------
.DS_Store
Thumbs.db
*.swp
*.swo

# ------------------------------------------------------------------------------
# pytest caches + temp dirs
# ------------------------------------------------------------------------------
.pytest_cache/
.cache/
**/pytest-*/

# ------------------------------------------------------------------------------
# Jupyter (if added later)
# ------------------------------------------------------------------------------
.ipynb_checkpoints/

# ------------------------------------------------------------------------------
# Diagrams (keep PNGs tracked)
# ------------------------------------------------------------------------------
diagrams/*.png
diagrams/*.svg
diagrams/*.jpg

# ------------------------------------------------------------------------------
# Pipeline configs (keep tracked)
# ------------------------------------------------------------------------------
!configs/logging.yml
!configs/pipeline.yml

# ------------------------------------------------------------------------------
# Environment files (keep tracked)
# ------------------------------------------------------------------------------
!environment.yml

# ------------------------------------------------------------------------------
# Raw ingestion artifacts (POS/QIES)
# ------------------------------------------------------------------------------
*.parquet
*.csv